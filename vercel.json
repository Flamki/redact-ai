{
  "buildCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://flamki-redactai.hf.space/api/:path*" },
    { "source": "/docs", "destination": "https://flamki-redactai.hf.space/docs" },
    { "source": "/openapi.json", "destination": "https://flamki-redactai.hf.space/openapi.json" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
